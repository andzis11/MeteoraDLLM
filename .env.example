# ============================================
# Meteora LP Bot - Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git!
# ============================================

# === WALLET ===
WALLET_PRIVATE_KEY=masukkan_private_key_base58_kamu_disini

# === RPC ===
RPC_URL=https://pump.helius-rpc.com

# === MINIMAX API ===
MINIMAX_API_KEY=masukkan_api_key_minimax_kamu

# === TELEGRAM ===
# Cara dapat token: chat @BotFather di Telegram
TELEGRAM_BOT_TOKEN=masukkan_token_bot_telegram
# Cara dapat chat_id: chat @userinfobot di Telegram
TELEGRAM_CHAT_ID=masukkan_chat_id_kamu
